{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",

    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "esModuleInterop": true,

    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "moduleDetection": "force",

    "skipLibCheck": true
  },

  "exclude": [
    "node_modules",
    "dist",
    "tsconfig.json"
  ]
}